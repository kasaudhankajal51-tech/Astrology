# Local development
# Option 1: Direct link to local backend (Best for debugging)
#VITE_API_URL=http://localhost:5000

# Option 2: Production link (Comment out when testing locally)
# Use the domain name without port 5000 since Nginx will handle SSL on port 443 and forward to port 5000.
VITE_API_URL=https://dsastroinstitute.com/api

