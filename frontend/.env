# Local development — Vite proxy handles both /api/* and /_/backend/* → localhost:5000
# VITE_API_URL is intentionally empty for local dev (proxy rewrites paths)
VITE_API_URL=

# --- PRODUCTION ---
# Set this in your deployment platform's environment variables:
# VITE_API_URL=/_/backend

API_BASE_URL="http://localhost:5173"